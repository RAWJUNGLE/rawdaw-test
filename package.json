{
  "name": "rawdaw-desktop",
  "version": "1.0.0",
  "description": "RAWDAW — native desktop build (Electron shell + C++ core).",
  "author": { "name": "RAWDAW", "email": "rawdaw@example.com" },
  "license": "SEE LICENSE IN native/rawcore/vendor",
  "main": "src/main/main.js",
  "scripts": {
    "postinstall": "npm --prefix native/rawcore install && npm run rebuild:native",
    "rebuild:native": "electron-rebuild -f -w rawcore --module-dir native/rawcore",
    "rebuild:native:node": "npm --prefix native/rawcore run rebuild",
    "test:native": "npm --prefix native/rawcore test",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac --arm64 --x64",
    "generate:icon": "node scripts/generate-icon.js",
    "build:native:universal": "node scripts/build-native-universal.js",
    "dist:mac:universal": "npm run generate:icon && npm run build:native:universal && CSC_IDENTITY_AUTO_DISCOVERY=false npx electron-builder --mac --universal --publish=never",
    "dist:mac:universal:quick": "CSC_IDENTITY_AUTO_DISCOVERY=false npx electron-builder --mac --universal --publish=never",
    "dist:win": "electron-builder --win --x64",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "extends": null,
    "appId": "com.rawdaw.desktop",
    "productName": "RAWDAW",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "native/rawcore/index.js",
      "native/rawcore/package.json",
      "native/rawcore/build/Release/rawcore.node",
      "!native/rawcore/build/**/*.o",
      "!native/rawcore/node_modules/**/*"
    ],
    "asarUnpack": [
      "native/rawcore/build/Release/rawcore.node"
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "build-resources/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["universal"] },
        { "target": "zip", "arch": ["universal"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": null,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "linux": {
      "category": "AudioVideo",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "@electron/rebuild": "^4.0.2"
  }
}
